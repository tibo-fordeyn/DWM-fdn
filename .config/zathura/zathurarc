### Settings from original zathurarc ###
set guioptions none
set page-padding 1
set statusbar-h-padding 0
set statusbar-w-padding 0
map u scroll half-up-
map d scroll half-down-
map D toggle_page_mode
map r reload
map R rotate
map , zoom out
map m zoom in
map J full-down
map K full-up
map D set "first-page-column 1:1"
map <C-d> set "first-page-column 1:2"
set selection-clipboard clipboard

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#c2c4c6'
set completion-bg '#080905'

# Command line completion group elements
set completion-group-fg '#3E4041'
set completion-group-bg '#080905'

# Current command line completion element
set completion-highlight-fg '#080905'
set completion-highlight-bg '#c2c4c6'

# Default foreground/background color
set default-bg rgba(8,9,5,0.9)

# Input bar
set inputbar-fg '#c2c4c6'
set inputbar-bg '#080905'

# Notification
set notification-fg '#c2c4c6'
set notification-bg '#080905'

# Error notification
set notification-error-fg '#c2c4c6'
set notification-error-bg '#4C4C31'

# Warning notification
set notification-warning-fg '#c2c4c6'
set notification-warning-bg '#4C4C31'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#c2c4c6'
set statusbar-bg '#080905'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#3E4041'
set highlight-active-color '#3E4041'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#c2c4c6'

# 'Loading...' text
set render-loading-fg '#c2c4c6'
set render-loading-bg '#080905'

# Index mode
set index-fg '#c2c4c6'
set index-bg '#080905'

# Selected element in index mode
set index-active-fg '#080905'
set index-active-bg '#c2c4c6'